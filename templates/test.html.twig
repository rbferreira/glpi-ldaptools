<div class="center">
    <div class="mb-2 d-flex justify-content-between align-items-center" style="max-width: 1400px; margin: 0 auto;">
        <div class="d-flex align-items-center gap-2">
            <label for="ldaptools-limit" class="mb-0">
                <i class="fas fa-sliders-h mr-1"></i> {{ __('Max entries:', 'ldaptools') }}
            </label>
            <select id="ldaptools-limit" class="form-select form-select-sm" style="width: auto;">
                <option value="5">5 ({{ __('fast', 'ldaptools') }})</option>
                <option value="50" selected>50</option>
                <option value="200">200</option>
                <option value="1000">1000</option>
                <option value="0">{{ __('Unlimited', 'ldaptools') }} ⚠️</option>
            </select>
            <small class="text-muted">{{ __('Higher values = slower test', 'ldaptools') }}</small>
        </div>
        <div>
            <button class="btn btn-sm btn-primary" id="ldaptools-run" title="{{ __('Run all diagnostic tests', 'ldaptools') }}">
                <i class="fas fa-play mr-1"></i> {{ __('Run Tests', 'ldaptools') }}
            </button>
        </div>
    </div>

    <table border="0" class="tab_cadrehov">
        <thead>
            <tr class="tab_bg_2">
                <th>{{ __('LDAP Server', 'ldaptools') }}</th>
                <th>
                    <i class="fas fa-globe mr-1"></i>
                    {{ __('DNS', 'ldaptools') }}
                </th>
                <th>
                    <i class="fas fa-plug mr-1"></i>
                    {{ __('TCP', 'ldaptools') }}
                </th>
                <th>
                    <i class="fas fa-sitemap mr-1"></i>
                    {{ __('BaseDN', 'ldaptools') }}
                </th>
                <th>
                    <i class="fas fa-link mr-1"></i>
                    {{ __('URI / TLS', 'ldaptools') }}
                </th>
                <th>
                    <i class="fas fa-key mr-1"></i>
                    {{ __('Bind', 'ldaptools') }}
                </th>
                <th>
                    {{ __('Search (cn=*)', 'ldaptools') }}
                </th>
                <th>
                    {{ __('Filter', 'ldaptools') }}
                </th>
                <th>
                    <i class="fas fa-tags mr-1"></i>
                    {{ __('Attrs', 'ldaptools') }}
                </th>
                <th>
                    <i class="fas fa-clock mr-1"></i>
                    {{ __('Total', 'ldaptools') }}
                </th>
            </tr>
        </thead>
        <tbody id="ldaptools-results">
            {% for ldap_items in ldap_servers %}
                <tr id="ldap_test_{{ ldap_items.master.id }}_0">
                    <td colspan="10" class="center text-muted">
                        <i class="fas fa-play-circle mr-1"></i>
                        {{ __('Click "Run Tests" to start diagnostics', 'ldaptools') }}
                    </td>
                </tr>
                {% for ldap_replicat in ldap_items.replicat %}
                    <tr id="ldap_test_{{ ldap_items.master.id }}_{{ ldap_replicat.id }}">
                        <td colspan="10" class="center text-muted">
                            <i class="fas fa-play-circle mr-1"></i>
                            {{ __('Click "Run Tests" to start diagnostics', 'ldaptools') }}
                        </td>
                    </tr>
                {% endfor %}
            {% endfor %}
        </tbody>
    </table>

    {% if ldap_servers|length == 0 %}
        <div class="alert alert-info mt-3 d-inline-block">
            <i class="fas fa-info-circle mr-1"></i>
            {{ __('No LDAP directories configured in GLPI. Go to Setup > Authentication > LDAP directories to add one.', 'ldaptools') }}
        </div>
    {% endif %}
</div>

<script>
    const ldapServersData = {{ ldap_servers|json_encode|raw }};
    const ajaxUrl = "{{ plugin_dir }}/ajax/test.php";

    function getLimit() {
        return parseInt(document.getElementById('ldaptools-limit').value) || 0;
    }

    function runAllTests() {
        Object.values(ldapServersData).forEach(ldapItems => {
            const masterId = ldapItems.master.id;
            $(`[id=ldap_test_${masterId}_0]`).html(
                '<td colspan="10" class="center"><i class="fas fa-spinner fa-pulse"></i> {{ __('Testing...', 'ldaptools') }}</td>'
            );
            ldapItems.replicat.forEach(rep => {
                $(`[id=ldap_test_${masterId}_${rep.id}]`).html(
                    '<td colspan="10" class="center"><i class="fas fa-spinner fa-pulse"></i> {{ __('Testing...', 'ldaptools') }}</td>'
                );
            });
        });

        Object.values(ldapServersData).forEach(ldapItems => {
            executeAjax(ldapItems.master);
            ldapItems.replicat.forEach(ldapReplicat => {
                executeAjax(ldapItems.master, ldapReplicat);
            });
        });
    }

    function executeAjax(ldap_master, ldap_replicat = {"id": 0}) {
        $.ajax({
            type: "GET",
            url: ajaxUrl,
            timeout: 300000,
            data: {
                authldaps_id: ldap_master.id,
                authldapreplicates_id: ldap_replicat.id,
                limit: getLimit()
            },
            success: function(data) {
                $(`[id=ldap_test_${ldap_master.id}_${ldap_replicat.id}]`).replaceWith(data);
            },
            error: function(xhr) {
                $(`[id=ldap_test_${ldap_master.id}_${ldap_replicat.id}]`).html(
                    `<td colspan="10" class="center" style="color: #ef4444;"><i class="fas fa-exclamation-circle mr-1"></i> AJAX error: ${xhr.status} ${xhr.statusText}</td>`
                );
            },
        });
    }

    $(document).ready(() => {
        $('#ldaptools-run').on('click', runAllTests);
    });
</script>
